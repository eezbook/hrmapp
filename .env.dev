# ─── LOCAL / DEVELOPMENT ──────────────────────────────────────────────────────
# Run with:  flutter run --flavor dev -t lib/main_dev.dart
#
# API_BASE_URL — use the IP that reaches your PC, NOT the hostname:
#   Android emulator  →  http://10.0.2.2/api/v1/hrm
#   Physical device   →  http://<your-wifi-ip>/api/v1/hrm
#                         (run `ipconfig`, look for Wi-Fi → IPv4 Address)
#   Web browser       →  http://localhost/api/v1/hrm
#
# DEV_HOST — your WAMP virtual host name.
#   Apache uses the Host header to decide which virtual host to serve.
#   Setting this makes requests from the emulator/device hit devacculyt.com
#   even though they go to an IP address.  Leave blank if not using vhosts.
# ──────────────────────────────────────────────────────────────────────────────

API_BASE_URL=http://localhost:8088/api/v1/hrm
DEV_HOST=devacculyt.com
CLIENT_NAME=HRM (Local)
PRIMARY_COLOR=4280391411
LOGO_ASSET=assets/images/logo_dev.png
